{
    "name": "pierre-arthur/sylius-upgrade-analyzer",
    "description": "Outil CLI d'audit automatisé de migration pour projets Sylius 1.x vers 2.x",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Pierre-Arthur Demengel",
            "email": "pierrearthur.demengel@gmail.com"
        }
    ],
    "keywords": ["sylius", "migration", "upgrade", "audit", "static-analysis", "php"],
    "require": {
        "php": ">=8.2",
        "nikic/php-parser": "^5.0",
        "symfony/console": "^6.4|^7.2",
        "symfony/finder": "^6.4|^7.2",
        "symfony/http-client": "^6.4|^7.2",
        "symfony/yaml": "^6.4|^7.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "symfony/framework-bundle": "^6.4|^7.2",
        "symfony/http-client-contracts": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PierreArthur\\SyliusUpgradeAnalyzer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PierreArthur\\SyliusUpgradeAnalyzer\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/sylius-upgrade-analyzer"
    ],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

{
    "name": "acme/sylius-shop",
    "type": "project",
    "description": "Acme Sylius E-Commerce Application",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "sylius/sylius": "~1.14.0",
        "sylius/invoicing-plugin": "^0.22",
        "bitbag/sylius-cms-plugin": "^4.0",
        "bitbag/sylius-wishlist-plugin": "^2.0",
        "setono/sylius-analytics-plugin": "^1.0",
        "some-vendor/unknown-sylius-plugin": "^1.0",
        "winzou/state-machine-bundle": "^0.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "symfony/browser-kit": "^5.4 || ^6.0",
        "lchrusciel/api-test-case": "^5.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "dealerdirect/phpcodesniffer-composer-installer": false
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^5.4 || ^6.0"
        }
    }
}

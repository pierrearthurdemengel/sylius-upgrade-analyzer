use Symfony\Component\Console\Application;
use Symfony\Component\HttpClient\HttpClient;

/* Détection du mode --no-marketplace avant la construction des analyseurs */
$noMarketplace = in_array('--no-marketplace', $argv, true);

/* Client HTTP partagé pour les appels réseau */
$httpClient = HttpClient::create();

/* Construction de la liste complète des analyseurs */
$analyzers = [
    // Templates & Frontend
    new TwigTemplateOverrideAnalyzer(),
    new SonataBlockEventAnalyzer(),
    new SemanticUiAnalyzer(),
    new JQueryAnalyzer(),
    new WebpackEncoreAnalyzer(),

    // Deprecations & Breaking Changes
    new WinzouStateMachineAnalyzer(),
    new SwiftMailerAnalyzer(),
    new UserEncoderAnalyzer(),
    new PayumAnalyzer(),
    new MessageBusRenameAnalyzer(),
    new CommandHandlerRenameAnalyzer(),
    new DeprecatedEmailManagerAnalyzer(),
    new RemovedPaymentGatewayAnalyzer(),
    new ServiceDecoratorAnalyzer(),
    new OrderProcessorPriorityAnalyzer(),
    new FormTypeExtensionPriorityAnalyzer(),
    new BehatContextDeprecationAnalyzer(),
    new AdminMenuEventAnalyzer(),
    new TranslationKeyAnalyzer(),
    new PromotionRuleCheckerAnalyzer(),
    new ShippingCalculatorAnalyzer(),
    new DoctrineXmlMappingAnalyzer(),
    new CustomFixtureAnalyzer(),
    new MultiStoreChannelAnalyzer(),
    new BundleConfigurationAnalyzer(),
    new CalendarClockAnalyzer(),
    new SecurityFirewallAnalyzer(),
    new UserModelFieldAnalyzer(),
    new RemovedClassAnalyzer(),
    new RenamedServiceIdAnalyzer(),
    new RemovedRouteAnalyzer(),
    new LiipImagineConfigAnalyzer(),
    new ConstructorSignatureAnalyzer(),
    new GridFilterEntityAnalyzer(),
    new UseWebpackConfigAnalyzer(),
    new PhpNodeVersionAnalyzer(),
    new ClassMoveAnalyzer(),
    new ServiceVisibilityAnalyzer(),
    new PaymentRequestEnvAnalyzer(),
    new DeprecatedBundlePackageAnalyzer(),
    new RemovedConfigKeyAnalyzer(),
    new RoutingImportAnalyzer(),

    // Plugins
    new PluginCompatibilityAnalyzer(
        new AddonsMarketplaceClient($httpClient),
        new PackagistClient($httpClient),
        $noMarketplace,
    ),

    // Grid & Resource
    new GridCustomizationAnalyzer(),
    new ResourceBundleAnalyzer(),

    // API Platform
    new ApiPlatformMigrationAnalyzer(),
    new ApiSerializationGroupAnalyzer(),
    new ApiEndpointRestructureAnalyzer(),
    new ApiQueryExtensionSignatureAnalyzer(),
];

/* Construction de la liste des reporters */
$jsonReporter = new JsonReporter();
$reporters = [
    new ConsoleReporter(),
    $jsonReporter,
    new SarifReporter(),
    new MarkdownReporter(),
    new CsvReporter(),
];

/* Construction du moteur de correctifs automatiques */
$fixers = [
    /* Fixers existants */
    new TwigHookFixer(),
    new WorkflowMigrationFixer(),
    new MessageBusFixer(),
    new SecurityConfigFixer(),
    new CommandHandlerFixer(),
    new SwiftMailerFixer(),
    new RenamedServiceIdFixer(),
    new SecurityFirewallFixer(),
    new LiipImagineConfigFixer(),
    new SonataBlockEventFixer(),
    new GridFilterEntityFixer(),
    new UseWebpackConfigFixer(),

    /* Fixers v1.4.0 — haute confiance */
    new CalendarToClockFixer(),
    new ClassMoveFixer(),
    new RemovedClassFixer(),
    new BundleConfigFixer(),
    new DeprecatedBundlePackageFixer(),
    new UserEncoderFixer(),
    new ApiEndpointRestructureFixer(),
    new RemovedRouteFixer(),
    new PaymentRequestEnvFixer(),
    new RoutingImportFixer(),
    new RemovedConfigKeyFixer(),

    /* Fixers v1.4.0 — confiance moyenne */
    new TranslationKeyFixer(),
    new BehatContextFixer(),
    new ApiSerializationGroupFixer(),
    new ApiQueryExtensionSignatureFixer(),
    new FormTypeExtensionPriorityFixer(),
    new OrderProcessorPriorityFixer(),
    new DeprecatedEmailManagerFixer(),
    new AdminMenuEventFixer(),
    new ServiceDecoratorFixer(),
    new RemovedPaymentGatewayFixer(),
    new ShippingCalculatorFixer(),
    new PromotionRuleCheckerFixer(),
    new PayumConfigFixer(),
    new GridCustomizationFixer(),
    new ResourceBundleFixer(),
    new ApiPlatformMigrationFixer(),

    /* Fixers v1.5.0 */
    new MultiStoreChannelFixer(),
    new ConstructorSignatureFixer(),
    new UserModelFieldFixer(),
    new DoctrineXmlMappingFixer(),
];
$fixEngine = new FixEngine($fixers);

/* Client API centralisé pour les services distants */
$apiClient = new ApiClient($httpClient);
$reportUploader = new ReportUploader($httpClient);
$reportLoader = new ReportLoader();

$application = new Application('sylius-upgrade-analyzer', '1.5.0');
$application->add(new AnalyzeCommand($analyzers, $reporters, $fixEngine));
$application->add(new UploadCommand($reportUploader));
$application->add(new MultiAnalyzeCommand($analyzers, $apiClient, $jsonReporter));
$application->add(new CompareCommand($reportLoader, $apiClient));
$application->add(new HistoryCommand($apiClient));
$application->add(new WebhookCommand($apiClient));
$application->setDefaultCommand('sylius-upgrade:analyze');
$application->run();
